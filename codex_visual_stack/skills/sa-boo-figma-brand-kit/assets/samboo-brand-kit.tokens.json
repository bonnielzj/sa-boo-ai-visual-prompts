{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "primitive": {
      "ivory-50": { "$type": "color", "$value": "#F7F3EA" },
      "ivory-100": { "$type": "color", "$value": "#EFE7D8" },
      "ink-900": { "$type": "color", "$value": "#111111" },
      "ink-700": { "$type": "color", "$value": "#2A2926" },
      "warmgray-100": { "$type": "color", "$value": "#E6DFD4" },
      "warmgray-300": { "$type": "color", "$value": "#B9AEA0" },
      "stone-500": { "$type": "color", "$value": "#8A8177" },
      "champagne-400": { "$type": "color", "$value": "#C8AA73" },
      "bronze-600": { "$type": "color", "$value": "#8B6438" },
      "silver-200": { "$type": "color", "$value": "#D8D8D6" },
      "silver-500": { "$type": "color", "$value": "#9B9B9A" },
      "accent-red": { "$type": "color", "$value": "#8A1F2D" }
    },
    "bg": {
      "deep": { "$type": "color", "$value": "{color.primitive.ink-900}" },
      "ivory": { "$type": "color", "$value": "{color.primitive.ivory-50}" },
      "paper": { "$type": "color", "$value": "{color.primitive.ivory-100}" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "{color.primitive.ink-900}" },
      "inverse": { "$type": "color", "$value": "{color.primitive.ivory-50}" },
